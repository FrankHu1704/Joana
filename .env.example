# ── Supabase (project: "Senga" — Joana Store tables are prefixed store_*) ──
NEXT_PUBLIC_SUPABASE_URL=https://vatvdkwuidtstyonwrwl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Joana Store

# ── WhatsApp (encomendas) ──────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=258864597500

# ── Push notifications (novo produto) ──────────────────────────────────────
# Gere um par com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@joanastore.co.mz

# ── Debito Pay (pagamentos automáticos: M-Pesa/e-Mola/mKesh via push USSD) ──
# Sem estas variáveis o checkout mantém-se automaticamente em modo WhatsApp.
# Cada carteira Debito Pay está presa a um único método de pagamento —
# defina um wallet_code por método usado (Merchant → Settings → API).
DEBITO_PAY_API_KEY=
DEBITO_PAY_MERCHANT_ID=
DEBITO_PAY_WALLET_CODE_MPESA=
DEBITO_PAY_WALLET_CODE_EMOLA=
DEBITO_PAY_WALLET_CODE_MKESH=
DEBITO_PAY_WALLET_CODE_VISA_MASTERCARD=
DEBITO_PAY_WALLET_CODE=
DEBITO_PAY_BASE_URL=https://gyqoaningqhurhvdugne.supabase.co/functions/v1
# Opcional — só necessário se registar um webhook (o polling já confirma
# o pagamento sem precisar de webhook).
DEBITO_PAY_WEBHOOK_SECRET=
